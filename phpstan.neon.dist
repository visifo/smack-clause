includes:
    - vendor/phpstan/phpstan/conf/bleedingEdge.neon
    - vendor/phpstan/phpstan-strict-rules/rules.neon

parameters:
    level: max
    paths:
        - src
        - tests
        - _smack_ide_helper.php
    phpVersion: 80500
    ignoreErrors:
        -
            identifier: method.internalClass
            path: tests/*
